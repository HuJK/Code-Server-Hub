#!/bin/bash
set +e
source /etc/code-server-hub/ENVSFILE
set -x

sync_user_groups() {
    local group_spec gid group_name container_group fallback_group

    for group_spec in $USERGROUPS; do
        gid="${group_spec%%:*}"
        group_name="${group_spec#*:}"

        if ! [[ "$gid" =~ ^[0-9]+$ ]]; then
            echo "Skipping invalid group id: $gid"
            continue
        fi

        container_group="$(getent group "$gid" | cut -d: -f1)"
        if [ -z "$container_group" ]; then
            if getent group "$group_name" >/dev/null; then
                fallback_group="hostgrp_${gid}"
                groupadd -g "$gid" "$fallback_group" || true
            else
                groupadd -g "$gid" "$group_name" || true
            fi
            container_group="$(getent group "$gid" | cut -d: -f1)"
        fi

        if [ -n "$container_group" ]; then
            usermod -aG "$container_group" "$USERNAME"
        else
            echo "Unable to sync host group ${group_name}:${gid}"
        fi
    done
}

sync_extra_container_groups() {
    local group_name

    for group_name in sudo root; do
        if getent group "$group_name" >/dev/null; then
            usermod -aG "$group_name" "$USERNAME"
        else
            echo "Unable to add missing container group: $group_name"
        fi
    done
}

sync_user_identity() {
    if ! id "$USERNAME" >/dev/null 2>&1; then
        useradd -u "$USERUID" -d /root "$USERNAME" --no-log-init --non-unique
    fi

    groupmod -g "$USERGID" "$USERNAME" || true
    sync_user_groups
    sync_extra_container_groups
}

link_dir() {
    local user_path="$1"
    local root_path="$2"
    mkdir -p "$user_path"
    mkdir -p "$(dirname "$root_path")"
    ln -s "$user_path" "$root_path"
    chown "$USERNAME:$USERNAME" "$user_path"
    chmod g+s /opt/miniconda
}

sync_user_identity

ROOTOWNER=$(stat -c '%U' /root)
if [ "$ROOTOWNER" != "$USERNAME" ]; then
    echo "First run, initing"
    ln -s /home/$USERNAME /root/$USERNAME
    ln -s /data /root/data
    echo "export PATH=$PATH:/usr/local/cuda/bin" > /etc/profile.d/20-nvcc.sh
    
    mkdir -p /root/.cache
    mkdir -p /root/.config
    rm -rf /opt/miniconda/envs
    
    link_dir "/home/$USERNAME/.cache/huggingface" "/root/.cache/huggingface"
    link_dir "/home/$USERNAME/.conda/envs"        "/opt/miniconda/envs"
    link_dir "/home/$USERNAME/.codex"             "/root/.codex"
    link_dir "/home/$USERNAME/.claude"            "/root/.claude"
    link_dir "/home/$USERNAME/.config/opencode"   "/root/.config/opencode"
    link_dir "/home/$USERNAME/.gemini"            "/root/.gemini"
    link_dir "/home/$USERNAME/.openclaw"          "/root/.openclaw"
    link_dir "/home/$USERNAME/.openharness"       "/root/.openharness"
    link_dir "/home/$USERNAME/.ohmo"              "/root/.ohmo"

    git config --global user.email "$USERNAME@example.com"
    git config --global user.name $USERNAME
    git config --global --add oh-my-zsh.hide-status 1
    git config --global --add oh-my-zsh.hide-dirty 1
    git config --global bash.showInformativeStatus false
    set -x
    chmod 700 /root
    chmod -R 700 /root/.oh-my-zsh
    chown -R $USERNAME:$USERNAME /root
    chown -R $USERNAME:$USERNAME /opt/fnm
    chown $USERNAME:$USERNAME /opt/miniconda
    chmod g+s /root
    chmod g+s /opt/fnm
    chmod g+s /opt/miniconda
    if [ ! -f "/home/$USERNAME/data" ] && [ ! -d "/home/$USERNAME/data" ]; then
        ln -s /data /home/$USERNAME/data || true
    fi
fi

/etc/init.d/cron start

echo "rcS finished. Runing /etc/rc.local"
parser=$(head -n 1 /etc/rc.local)
eval ${parser:2} /etc/rc.local &
